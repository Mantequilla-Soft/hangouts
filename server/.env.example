LIVEKIT_HOST=https://livekit.yourproject.com
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
SESSION_SECRET=generate-a-random-64-char-string-here
HIVE_API_NODE=https://api.hive.blog

# Audio recording publish path (audio.3speak.tv → IPFS).
# Leave AUDIO_API_KEY empty to disable the legacy direct-IPFS upload route;
# new integrations use the SDK's onAudioHandoff callback instead.
AUDIO_API_URL=https://audio.3speak.tv
AUDIO_API_KEY=your_audio_api_key_here

# 3Speak embed-uploads service used by the recording → studio handoff and
# any embed-style asset uploads from the server. Defaults match production.
EMBED_UPLOAD_URL=https://embed.3speak.tv/uploads
EMBED_API_URL=https://embed.3speak.tv/api
EMBED_API_KEY=your_embed_api_key_here

# Long-form video upload service used by the /studio publish path
# (separate from shorts). Token is the bearer used by server-side
# uploads on the user's behalf.
VIDEO_UPLOAD_URL=https://video.3speak.tv
VIDEO_UPLOAD_TOKEN=your_video_upload_token_here

# 3Speak frontend base URL used to build studio share-links the server
# returns to clients (e.g. embed-studio handoff URLs).
STUDIO_FRONTEND_URL=https://3speak.tv

MONGODB_URI=mongodb://localhost:27017/your_3speak_db

# Boost (superchat) pipeline
# Set BOOSTS_ENABLED=true to enable listener + ingest endpoints.
BOOSTS_ENABLED=false
# Platform wallet that receives incoming boost transfers.
BOOST_PLATFORM_ACCOUNT=your_boost_wallet_account
# Active key for BOOST_PLATFORM_ACCOUNT. Keep this server-only and secret-managed.
BOOST_PLATFORM_ACTIVE_KEY=your_platform_active_key_here
# Platform fee percent retained from each accepted boost (e.g. 5 = 5%).
BOOST_PLATFORM_FEE_PERCENT=5
# HIVE/USD is pulled from CoinGecko and cached in-memory.
# If CoinGecko is unavailable, fallback is used.
BOOST_HIVE_USD_FALLBACK=0.25
BOOST_HIVE_USD_CACHE_MS=120000

PORT=3002
