server {
    listen 80;
    server_name livekit.okinoko.io;

    # Lets-Encrypt HTTP-01 challenges land here pre-TLS. After running
    # `certbot --nginx -d livekit.okinoko.io` certbot rewrites this to add the
    # 443 ssl block and redirect 80 → 443.

    location / {
        proxy_pass http://127.0.0.1:7880;
        proxy_http_version 1.1;

        # WebSocket upgrade for LiveKit signaling (wss://livekit.okinoko.io)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket connections are long-lived
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_buffering off;
    }
}
